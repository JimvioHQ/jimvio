NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Used for email links (signup, OAuth, password reset). Supabase must allow this origin + /auth/callback and /reset-password
NEXT_PUBLIC_APP_URL=http://localhost:3000

# If you use .env.local, it overrides .env for the same variable names — remove placeholder PesaPal keys there or copy real keys.

# PesaPal (African fiat — MTN, Airtel, card; sandbox vs live)
# Get real credentials from https://developer.pesapal.com (download API 3.0 test / sandbox credentials).
# Do not leave empty or example placeholders — PesaPal will reject them. Run: npm run pesapal:verify
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
# sandbox → https://cybqa.pesapal.com/pesapalv3  |  live → https://pay.pesapal.com/v3
PESAPAL_ENV=sandbox
# Optional: when order currency is USD, convert to RWF before PesaPal SubmitOrder (country sandbox merchants often need local currency). Uses RWF_TO_USD_RATE.
# PESAPAL_CHECKOUT_CURRENCY=RWF

# Shopify (Partner/Dev Dashboard → your app → Settings → Credentials)
# Client ID — OAuth / CLI
SHOPIFY_CLIENT_ID=
# Client secret (shpss_…) — webhook HMAC verification for /api/webhooks/shopify; NOT from a separate “webhooks section”
SHOPIFY_WEBHOOK_SECRET=
# Optional: platform catalog via Admin API without shopify_credentials — use with JIMVIO_PLATFORM_SHOPIFY_VENDOR_ID
# Store: Settings → Develop apps → Admin API access token (shpat_…)
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ACCESS_TOKEN=
# e.g. 2024-07 or 2026-01 (must match an API version Shopify still serves)
SHOPIFY_API_VERSION=
# Random long string; send as Authorization: Bearer <value> to protected /api/cron/* routes (not the Shopify secret)
CRON_SECRET=
# One vendors.id UUID for platform-operated Shopify (see database/migrations/023_platform_shopify_vendor.sql)
JIMVIO_PLATFORM_SHOPIFY_VENDOR_ID=
JIMVIO_PLATFORM_WALLET_USER_ID=
# Default Jimvio % on Shopify sales when connecting a store (overridable in shopify_credentials)
SHOPIFY_DEFAULT_PLATFORM_COMMISSION_RATE=8

# PawaPay (mobile money — MTN, Airtel, etc.)
# Sandbox: https://dashboard.sandbox.pawapay.io + https://api.sandbox.pawapay.io
# Production: https://dashboard.pawapay.io + https://api.pawapay.io (separate token; never mix with sandbox)
# Optional: explicit API base (overrides PAWAPAY_ENV). No trailing slash. See docs/pawapay-sandbox-ngrok.md
# PAWAPAY_BASE_URL=https://api.pawapay.io
PAWAPAY_API_TOKEN=
# Force Bearer-only (no HTTP signatures). Set true if you use only the API token and disabled signed requests in the dashboard.
# PAWAPAY_HTTP_SIGNING_DISABLED=true
# Optional HTTP signatures (RFC 9421). Omit these if you disable "signed financial requests" in the PawaPay dashboard (Bearer-only).
# If you get HTTP 401 HTTP_SIGNATURE_ERROR, either disable signing in the dashboard OR set:
# PAWAPAY_HTTP_SIGNING_KEY_ID=your_key_id_from_dashboard
# PAWAPAY_HTTP_SIGNING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Optional: default ecdsa-p256-sha256; for RSA try rsa-v1_5-sha256 or rsa-pss-sha512
# PAWAPAY_HTTP_SIGNING_ALG=ecdsa-p256-sha256
# sandbox | production (selects api.sandbox.pawapay.io vs api.pawapay.io)
PAWAPAY_ENV=production
# Optional default MMO provider for /api/deposit demo (v2 id, e.g. MTN_MOMO_RWA)
# PAWAPAY_DEFAULT_PROVIDER=MTN_MOMO_RWA
# Optional MSISDN for POST /api/test-pawapay (Rwanda test number)
# PAWAPAY_TEST_PHONE=2507XXXXXXXX
# USD → ZMW for PawaPay when order is USD and customer picks a ZMW provider (Kwacha per 1 USD)
PAWAPAY_ZMW_PER_USD=25
NEXT_PUBLIC_PAWAPAY_ZMW_PER_USD=25
# Optional JSON array of { "id": "MTN_MOMO_ZMB", "label": "…", "currency": "ZMW" } — must match order currency
# NEXT_PUBLIC_PAWAPAY_PROVIDERS=[{"id":"MTN_MOMO_RWA","label":"MTN Rwanda (RWF)","currency":"RWF"}]

# NowPayments (optional crypto checkout)
# API key must match NOWPAYMENTS_ENV: sandbox keys from dashboard (sandbox mode) for api-sandbox.nowpayments.io; production keys for api.nowpayments.io
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
# sandbox | production (case-insensitive; unset = production API)
NOWPAYMENTS_ENV=sandbox
NEXT_PUBLIC_NOWPAYMENTS_PUBLIC_KEY=
RWF_TO_USD_RATE=0.0008
# Same numeric value as RWF_TO_USD_RATE so client components can show RWF-stored prices as USD (optional but recommended)
NEXT_PUBLIC_RWF_TO_USD_RATE=0.0008

# ── Step 6 — multi-gateway router (lib/payments/router.ts) + FX (lib/currency/rates.ts) ──
# PAWAPAY_API_TOKEN, PESAPAL_*, NOWPAYMENTS_* are defined above; do not duplicate.
# These are alternate / additional flags used by the new gateway modules:
PAWAPAY_SANDBOX=
PESAPAL_SANDBOX=
AFRIPAY_API_KEY=
AFRIPAY_SANDBOX=
EXCHANGE_RATE_API_URL=
FX_CACHE_TTL_MINUTES=
