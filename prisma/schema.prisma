  @@unique([buyer_id, vendor_id])
  @@index([buyer_id], map: "idx_conversations_buyer")
  @@index([vendor_id], map: "idx_conversations_vendor")
  @@schema("public")
}

model conversation_messages {
  id                          String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id             String                  @db.Uuid
  sender_id                   String                  @db.Uuid
  body                        String?                 @default("")
  created_at                  DateTime                @default(now()) @db.Timestamptz(6)
  message_type                String                  @default("text")
  reply_to_id                 String?                 @db.Uuid
  metadata                    Json                    @default("{}")

  conversations               conversations           @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  conversation_messages       conversation_messages?  @relation("conversation_messagesToconversation_messages", fields: [reply_to_id], references: [id], onUpdate: NoAction)
  other_conversation_messages conversation_messages[] @relation("conversation_messagesToconversation_messages")
  profiles                    profiles                @relation(fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([conversation_id], map: "idx_conversation_messages_conversation")
  @@index([conversation_id, created_at], map: "idx_conversation_messages_created")
  @@index([reply_to_id], map: "idx_conversation_messages_reply_to")
  @@schema("public")
}

// ── Misc ──────────────────────────────────────

model notifications {
  id         String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String            @db.Uuid
  type       notification_type
  title      String
  message    String
  data       Json?             @default("{}")
  is_read    Boolean?          @default(false)
  read_at    DateTime?         @db.Timestamptz(6)
  action_url String?
  created_at DateTime?         @default(now()) @db.Timestamptz(6)
  profiles   profiles          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, is_read], map: "idx_notifications_unread", where: raw("(is_read = false)"))
  @@index([user_id], map: "idx_notifications_user_id")
  @@schema("public")
}

model blog_posts {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug              String   @unique
  title             String
  excerpt           String
  author_name       String
  published_at      DateTime @default(now()) @db.Timestamptz(6)
  read_time_minutes Int      @default(5)
  category          String   @default("General")
  image_url         String?
  body              String?
  is_published      Boolean  @default(false)
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  @@index([is_published, published_at(sort: Desc)], map: "blog_posts_published_idx")
  @@schema("public")
}

model buying_requests {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buyer_id           String               @db.Uuid
  product_name       String
  category           String?
  quantity_needed    Decimal              @default(1) @db.Decimal
  budget_min         Decimal?             @db.Decimal
  budget_max         Decimal?             @db.Decimal
  delivery_country   String?
  description        String?
  status             String               @default("open")
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)

  profiles           profiles             @relation(fields: [buyer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  buying_lead_offers buying_lead_offers[]

  @@index([buyer_id], map: "idx_buying_requests_buyer")
  @@index([status], map: "idx_buying_requests_status")
  @@schema("public")
}

model buying_lead_offers {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buying_request_id String          @db.Uuid
  vendor_id         String          @db.Uuid
  message           String?
  offered_price     Decimal?        @db.Decimal
  status            String          @default("pending")
  created_at        DateTime        @default(now()) @db.Timestamptz(6)

  buying_requests   buying_requests @relation(fields: [buying_request_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vendors           vendors         @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([buying_request_id], map: "idx_buying_lead_offers_request")
  @@schema("public")
}

model platform_settings {
  key        String   @id
  value      Json     @default("{}")
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([updated_at(sort: Desc)])
  @@schema("public")
}
