generator client {
  provider        = "prisma-client"
  output          = "../lib/generated/prisma"
  previewFeatures = ["multiSchema", "partialIndexes"]
}

datasource db {
  provider  = "postgresql"
  schemas   = ["public"]
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum campaign_status {
  draft
  active
  paused
  completed
  cancelled

  @@schema("public")
}

enum notification_type {
  order
  payment
  affiliate
  influencer
  community
  system
  review
  message

  @@schema("public")
}

enum order_status {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
  completed

  @@schema("public")
}

enum payment_status {
  pending
  processing
  completed
  failed
  refunded
  cancelled
  paid

  @@schema("public")
}

enum payout_status {
  pending
  processing
  paid
  failed

  @@schema("public")
}

enum product_status {
  draft
  active
  paused
  archived

  @@schema("public")
}

enum product_type {
  physical
  digital
  subscription
  course
  software
  template
  ebook

  @@schema("public")
}

enum ugc_campaign_status {
  draft
  active
  paused
  completed
  cancelled

  @@schema("public")
}

enum ugc_campaign_type {
  clipping
  ugc
  music_clipping
  promotion

  @@schema("public")
}

enum ugc_media_type {
  image
  video
  file

  @@schema("public")
}

enum ugc_media_usage {
  banner
  example
  ad_creative

  @@schema("public")
}

enum ugc_participation_status {
  invited
  accepted
  rejected
  banned

  @@schema("public")
}

enum ugc_payment_model {
  per_views
  fixed_per_content

  @@schema("public")
}

enum ugc_payout_status {
  pending
  approved
  paid

  @@schema("public")
}

enum ugc_platform {
  tiktok
  instagram
  youtube
  x

  @@schema("public")
}

enum ugc_platform_format {
  reels
  tiktok_video
  youtube_short
  post
  story

  @@schema("public")
}

enum ugc_submission_status {
  pending
  approved
  rejected
  removed

  @@schema("public")
}

enum user_role {
  buyer
  vendor
  affiliate
  influencer
  community_owner
  admin

  @@schema("public")
}

enum verification_status {
  pending
  verified
  rejected
  suspended

  @@schema("public")
}

// ─────────────────────────────────────────────
// MODELS — public schema only
// ─────────────────────────────────────────────

/// Central user profile — mirrors auth.users via shared UUID primary key.
/// All app logic should reference this table rather than auth.users directly.
model profiles {
  id                 String  @id @db.Uuid // same UUID as auth.users.id
  email              String  @unique
  username           String? @unique
  full_name          String?
  avatar_url         String?
  bio                String?
  website            String?
  phone              String?
  country            String? @default("RW")
  city               String?
  timezone           String? @default("Africa/Kigali")
  language           String? @default("en")
  is_verified        Boolean? @default(false)
  is_active          Boolean? @default(true)
  two_factor_enabled Boolean? @default(false)
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
  updated_at         DateTime? @default(now()) @db.Timestamptz(6)

  // Relations
  affiliates                                                                      affiliates?
  buying_requests                                                                 buying_requests[]
  communities                                                                     communities[]
  community_courses                                                               community_courses[]
  community_inbox_conversations_community_inbox_conversations_user_highToprofiles community_inbox_conversations[] @relation("community_inbox_conversations_user_highToprofiles")
  community_inbox_conversations_community_inbox_conversations_user_lowToprofiles  community_inbox_conversations[] @relation("community_inbox_conversations_user_lowToprofiles")
  community_inbox_messages                                                        community_inbox_messages[]
  community_memberships                                                           community_memberships[]
  community_messages                                                              community_messages[]
  community_payments                                                              community_payments[]
  community_post_comments                                                         community_post_comments[]
  community_post_likes                                                            community_post_likes[]
  community_posts                                                                 community_posts[]
  community_saved_posts                                                           community_saved_posts[]
  community_tasks                                                                 community_tasks[]
  conversations                                                                   conversations[]
  influencers                                                                     influencers?
  lesson_progress                                                                 lesson_progress[]
  member_points                                                                   member_points[]
  notifications                                                                   notifications[]
  orders                                                                          orders[]
  payouts                                                                         payouts[]
  product_views                                                                   product_views[]
  reviews                                                                         reviews[]
  short_video_comments                                                            short_video_comments[]
  short_videos                                                                    short_videos[]
  task_completions_task_completions_reviewed_byToprofiles                         task_completions[] @relation("task_completions_reviewed_byToprofiles")
  task_completions_task_completions_user_idToprofiles                             task_completions[] @relation("task_completions_user_idToprofiles")
  transactions                                                                    transactions[]
  ugc_campaign_escrow                                                             ugc_campaign_escrow[]
  ugc_reports_ugc_reports_reporter_idToprofiles                                   ugc_reports[] @relation("ugc_reports_reporter_idToprofiles")
  ugc_reports_ugc_reports_reviewed_byToprofiles                                   ugc_reports[] @relation("ugc_reports_reviewed_byToprofiles")
  ugc_submissions                                                                 ugc_submissions[]
  user_roles                                                                      user_roles[]
  vendor_followers                                                                vendor_followers[]
  vendors                                                                         vendors[]
  wallets                                                                         wallets?
  wishlists                                                                       wishlists[]

  @@index([email], map: "idx_profiles_email")
  @@index([username], map: "idx_profiles_username")
  @@schema("public")
  shortVideoClicks short_video_clicks[]
  conversationMessages conversation_messages[]
}

model user_roles {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id      String    @db.Uuid
  role         user_role
  is_active    Boolean?  @default(true)
  activated_at DateTime? @default(now()) @db.Timestamptz(6)
  profiles     profiles  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, role])
  @@index([role], map: "idx_user_roles_role")
  @@index([user_id], map: "idx_user_roles_user_id")
  @@schema("public")
}

// ── Marketplace ───────────────────────────────

model vendors {
  id                        String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id                   String               @db.Uuid
  business_name             String
  business_slug             String               @unique
  business_description      String?
  business_logo             String?
  business_banner           String?
  business_email            String?
  business_phone            String?
  business_address          String?
  business_country          String?              @default("RW")
  tax_id                    String?
  website                   String?
  verification_status       verification_status? @default(pending)
  verification_notes        String?
  verified_at               DateTime?            @db.Timestamptz(6)
  rating                    Decimal?             @default(0) @db.Decimal(3, 2)
  total_sales               Int?                 @default(0)
  total_revenue             Decimal?             @default(0) @db.Decimal(14, 2)
  commission_rate           Decimal?             @default(0) @db.Decimal(5, 2)
  affiliate_enabled         Boolean?             @default(true)
  affiliate_commission_rate Decimal?             @default(10) @db.Decimal(5, 2)
  stripe_account_id         String?
  payout_method             String?              @default("mtn")
  payout_account            String?
  is_featured               Boolean?             @default(false)
  is_active                 Boolean?             @default(true)
  created_at                DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at                DateTime?            @default(now()) @db.Timestamptz(6)
  follower_count            Int?                 @default(0)
  business_type             String?
  product_categories        String?

  profiles              profiles                @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  affiliate_commissions affiliate_commissions[]
  affiliate_links       affiliate_links[]
  buying_lead_offers    buying_lead_offers[]
  conversations         conversations[]
  order_items           order_items[]
  orders                orders[]
  products              products[]
  reviews               reviews[]
  shopify_credentials   shopify_credentials?
  ugc_campaigns         ugc_campaigns[]
  vendor_followers      vendor_followers[]

  @@index([business_name(ops: raw("gin_trgm_ops"))], map: "idx_vendors_name_trgm", type: Gin)
  @@index([business_slug], map: "idx_vendors_slug")
  @@index([user_id], map: "idx_vendors_user_id")
  @@index([verification_status], map: "idx_vendors_verification")
  @@schema("public")
}

model vendor_followers {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vendor_id  String    @db.Uuid
  user_id    String    @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  profiles   profiles  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vendors    vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([vendor_id, user_id], map: "idx_vendor_followers_composite")
  @@unique([vendor_id, user_id])
  @@index([vendor_id], map: "idx_vendor_followers_count")
  @@schema("public")
}

model product_categories {
  id                       String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  parent_id                String?              @db.Uuid
  name                     String
  slug                     String               @unique
  description              String?
  icon                     String?
  image_url                String?
  color                    String?
  is_active                Boolean?             @default(true)
  sort_order               Int?                 @default(0)
  product_count            Int?                 @default(0)
  created_at               DateTime?            @default(now()) @db.Timestamptz(6)
  category_type            String               @default("physical")
  product_categories       product_categories?  @relation("product_categoriesToproduct_categories", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_product_categories product_categories[] @relation("product_categoriesToproduct_categories")
  products                 products[]

  @@schema("public")
}

model products {
  id                        String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vendor_id                 String         @db.Uuid
  category_id               String?        @db.Uuid
  name                      String
  slug                      String         @unique
  short_description         String?
  description               String?
  product_type              product_type?  @default(physical)
  status                    product_status? @default(draft)
  price                     Decimal        @default(0) @db.Decimal(14, 2)
  compare_at_price          Decimal?       @db.Decimal(14, 2)
  cost_price                Decimal?       @db.Decimal(14, 2)
  currency                  String?        @default("RWF")
  sku                       String?        @unique
  barcode                   String?
  weight                    Decimal?       @db.Decimal(10, 3)
  dimensions                Json?
  images                    Json?          @default("[]")
  videos                    Json?          @default("[]")
  tags                      String[]
  meta_title                String?
  meta_description          String?
  is_digital                Boolean?       @default(false)
  digital_file_url          String?
  digital_file_size         BigInt?
  requires_shipping         Boolean?       @default(true)
  track_inventory           Boolean?       @default(true)
  inventory_quantity        Int?           @default(0)
  low_stock_threshold       Int?           @default(5)
  allow_backorder           Boolean?       @default(false)
  affiliate_enabled         Boolean?       @default(true)
  affiliate_commission_rate Decimal?       @db.Decimal(5, 2)
  influencer_enabled        Boolean?       @default(true)
  is_featured               Boolean?       @default(false)
  is_active                 Boolean?       @default(true)
  view_count                Int?           @default(0)
  sale_count                Int?           @default(0)
  rating                    Decimal?       @default(0) @db.Decimal(3, 2)
  review_count              Int?           @default(0)
  wishlist_count            Int?           @default(0)
  published_at              DateTime?      @db.Timestamptz(6)
  created_at                DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at                DateTime?      @default(now()) @db.Timestamptz(6)
  shopify_product_id        String?
  shopify_variant_id        BigInt?
  shopify_handle            String?
  shopify_synced_at         DateTime?      @db.Timestamptz(6)
  source                    String?        @default("vendor")
  source_metadata           Json           @default("{}")
  price_usd                 Decimal        @default(0) @db.Decimal(10, 2)
  button_text               String?
  pricing_type              String?        @default("one_time")
  billing_period            String?

  product_categories    product_categories?     @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendors               vendors                 @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  affiliate_commissions affiliate_commissions[]
  affiliate_links       affiliate_links[]
  order_items           order_items[]
  product_variants      product_variants[]
  product_views         product_views[]
  reviews               reviews[]
  short_video_clicks    short_video_clicks[]
  short_videos          short_videos[]
  wishlists             wishlists[]

  @@unique([shopify_product_id, vendor_id], map: "idx_products_shopify_id", where: raw("(shopify_product_id IS NOT NULL)"))
  @@index([is_active], map: "idx_products_active", where: raw("(is_active = true)"))
  @@index([category_id], map: "idx_products_category_id")
  @@index([is_featured], map: "idx_products_featured", where: raw("(is_featured = true)"))
  @@index([name(ops: raw("gin_trgm_ops"))], map: "idx_products_name_trgm", type: Gin)
  @@index([product_type], map: "idx_products_product_type")
  @@index([slug], map: "idx_products_slug")
  @@index([source], map: "idx_products_source")
  @@index([status], map: "idx_products_status")
  @@index([product_type], map: "idx_products_type")
  @@index([vendor_id], map: "idx_products_vendor_id")
  @@schema("public")
}

model product_variants {
  id                 String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  product_id         String    @db.Uuid
  name               String
  sku                String?   @unique
  price              Decimal   @db.Decimal(14, 2)
  compare_at_price   Decimal?  @db.Decimal(14, 2)
  inventory_quantity Int?      @default(0)
  image_url          String?
  options            Json?     @default("{}")
  is_active          Boolean?  @default(true)
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
  order_items        order_items[]
  products           products  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

model product_views {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  product_id  String    @db.Uuid
  user_id     String?   @db.Uuid
  session_id  String?
  ip_address  String?   @db.Inet
  referrer    String?
  country     String?
  device_type String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  products    products  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles    profiles? @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_product_views_created_at")
  @@index([product_id], map: "idx_product_views_product_id")
  @@schema("public")
}

model wishlists {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String    @db.Uuid
  product_id String    @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  products   products  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles   profiles  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, product_id])
  @@schema("public")
}

model reviews {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  product_id           String?   @db.Uuid
  buyer_id             String    @db.Uuid
  order_item_id        String?   @db.Uuid
  vendor_id            String?   @db.Uuid
  rating               Int
  title                String?
  body                 String?
  images               Json?     @default("[]")
  is_verified_purchase Boolean?  @default(false)
  is_featured          Boolean?  @default(false)
  helpful_count        Int?      @default(0)
  vendor_reply         String?
  vendor_replied_at    DateTime? @db.Timestamptz(6)
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
  updated_at           DateTime? @default(now()) @db.Timestamptz(6)

  profiles    profiles     @relation(fields: [buyer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  order_items order_items? @relation(fields: [order_item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products    products?    @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vendors     vendors?     @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([product_id, buyer_id])
  @@schema("public")
}

model shopify_credentials {
  id                       String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vendor_id                String    @unique @db.Uuid
  shop_domain              String
  access_token             String
  api_version              String    @default("2024-07")
  platform_commission_rate Decimal   @default(8) @db.Decimal
  connected_at             DateTime? @default(now()) @db.Timestamptz(6)
  last_synced_at           DateTime? @db.Timestamptz(6)
  is_active                Boolean?  @default(true)
  vendors                  vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([shop_domain], map: "idx_shopify_creds_domain")
  @@schema("public")
}

// ── Orders & Transactions ─────────────────────

model orders {
  id               String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  order_number     String          @unique @default(dbgenerated("('ORD-'::text || upper(\"substring\"((gen_random_uuid())::text, 1, 8)))"))
  buyer_id         String          @db.Uuid
  vendor_id        String?         @db.Uuid
  affiliate_id     String?         @db.Uuid
  status           order_status?   @default(pending)
  payment_status   payment_status? @default(pending)
  subtotal         Decimal         @default(0) @db.Decimal(14, 2)
  discount_amount  Decimal?        @default(0) @db.Decimal(14, 2)
  shipping_amount  Decimal?        @default(0) @db.Decimal(14, 2)
  tax_amount       Decimal?        @default(0) @db.Decimal(14, 2)
  total_amount     Decimal         @db.Decimal(14, 2)
  currency         String?         @default("RWF")
  shipping_address Json?
  billing_address  Json?
  notes            String?
  metadata         Json?           @default("{}")
  paid_at          DateTime?       @db.Timestamptz(6)
  shipped_at       DateTime?       @db.Timestamptz(6)
  delivered_at     DateTime?       @db.Timestamptz(6)
  cancelled_at     DateTime?       @db.Timestamptz(6)
  created_at       DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?       @default(now()) @db.Timestamptz(6)

  // Shopify fulfillment
  integration_source         String?
  shopify_order_id           String?
  shopify_order_number       Int?
  shopify_fulfillment_status String?  @default("unfulfilled")
  shopify_order_ids          String[] @default([])
  tracking_number            String?
  tracking_status            String?

  profiles              profiles                @relation(fields: [buyer_id], references: [id])
  vendors               vendors?                @relation(fields: [vendor_id], references: [id])
  order_items           order_items[]
  order_status_history  order_status_history[]
  affiliate_commissions affiliate_commissions[]
  exchange_rate_logs    exchange_rate_logs[]
  transactions          transactions[]
  webhook_events        webhook_events[]

  @@index([buyer_id], map: "idx_orders_buyer_id")
  @@index([vendor_id], map: "idx_orders_vendor_id")
  @@index([status], map: "idx_orders_status")
  @@index([payment_status], map: "idx_orders_payment_status")
  @@index([created_at(sort: Desc)], map: "idx_orders_created_at")
  @@index([integration_source], map: "idx_orders_integration_source")
  @@schema("public")
}

model order_items {
  id                          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  order_id                    String    @db.Uuid
  product_id                  String?   @db.Uuid
  variant_id                  String?   @db.Uuid
  vendor_id                   String?   @db.Uuid
  product_name                String
  product_image               String?
  variant_name                String?
  quantity                    Int       @default(1)
  unit_price                  Decimal   @db.Decimal(14, 2)
  total_price                 Decimal   @db.Decimal(14, 2)
  affiliate_id                String?   @db.Uuid
  affiliate_commission_rate   Decimal?  @db.Decimal(5, 2)
  affiliate_commission_amount Decimal?  @db.Decimal(14, 2)
  digital_download_url        String?
  download_count              Int?      @default(0)
  created_at                  DateTime? @default(now()) @db.Timestamptz(6)
  shopify_variant_id          BigInt?
  shopify_product_id          String?
  product_source              String    @default("vendor")
  source_metadata             Json      @default("{}")
  metadata                    Json?     @default("{}")
  product_type                String?   @default("physical")
  access_granted_at           DateTime? @db.Timestamptz(6)
  pricing_type                String?   @default("one_time")
  billing_period              String?

  orders           orders            @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products         products?         @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product_variants product_variants? @relation(fields: [variant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendors          vendors?          @relation(fields: [vendor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  affiliate_commissions affiliate_commissions[]
  reviews          reviews[]

  @@index([order_id], map: "idx_order_items_order_id")
  @@index([pricing_type], map: "idx_order_items_pricing_type")
  @@index([product_id], map: "idx_order_items_product_id")
  @@index([product_source], map: "idx_order_items_product_source")
  @@index([product_type], map: "idx_order_items_product_type")
  @@schema("public")
}

model order_status_history {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id        String    @db.Uuid
  user_id         String?   @db.Uuid
  previous_status String?
  new_status      String
  notes           String?
  metadata        Json?
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  orders          orders    @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([order_id], map: "idx_order_status_history_order_id")
  @@schema("public")
}

model transactions {
  id                      String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id                 String         @db.Uuid
  order_id                String?        @db.Uuid
  webhook_event_id        String?        @db.Uuid
  type                    String
  direction               String         @default("credit")
  amount                  Decimal        @db.Decimal(14, 2)
  currency                String         @default("RWF")
  amount_usd              Decimal?       @db.Decimal(10, 2)
  exchange_rate           Decimal?       @db.Decimal(14, 6)
  status                  payment_status @default(pending)
  provider                String?
  provider_transaction_id String?
  description             String?
  metadata                Json           @default("{}")
  created_at              DateTime       @default(now()) @db.Timestamptz(6)
  updated_at              DateTime       @default(now()) @db.Timestamptz(6)

  orders         orders?         @relation(fields: [order_id], references: [id])
  profiles       profiles        @relation(fields: [user_id], references: [id])
  webhook_events webhook_events? @relation(fields: [webhook_event_id], references: [id])

  @@unique([provider, provider_transaction_id])
  @@index([order_id])
  @@index([user_id])
  @@index([status])
  @@index([webhook_event_id])
  @@schema("public")
}

model exchange_rate_logs {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  from_currency String
  to_currency   String
  rate          Decimal   @db.Decimal(14, 6)
  order_id      String?   @db.Uuid
  recorded_at   DateTime? @default(now()) @db.Timestamptz(6)
  orders        orders?   @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model webhook_events {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider        String
  idempotency_key String         @unique
  payload         Json?
  status          String         @default("received")
  error           String?
  order_id        String?        @db.Uuid
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime       @default(now()) @db.Timestamptz(6)
  orders          orders?        @relation(fields: [order_id], references: [id], onUpdate: NoAction)
  transactions    transactions[]

  @@index([order_id], where: raw("(order_id IS NOT NULL)"))
  @@index([provider, created_at(sort: Desc)], map: "webhook_events_provider_idx")
  @@index([status, created_at(sort: Desc)], map: "webhook_events_status_idx")
  @@schema("public")
}

model payouts {
  id                 String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id            String        @db.Uuid
  type               String
  amount             Decimal       @db.Decimal(14, 2)
