  @@index([snapshotted_at(sort: Desc)], map: "idx_ugc_view_snapshots_at")
  @@index([submission_id], map: "idx_ugc_view_snapshots_submission_id")
  @@schema("public")
}

model ugc_payouts {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submission_id   String            @db.Uuid
  influencer_id   String            @db.Uuid
  amount          Decimal           @default(0.00) @db.Decimal(12, 2)
  status          ugc_payout_status @default(pending)
