  ugc_campaign_media        ugc_campaign_media[]
  ugc_campaign_participants ugc_campaign_participants[]
  ugc_submissions           ugc_submissions[]

  @@index([brand_id], map: "idx_ugc_campaigns_brand_id")
  @@index([status], map: "idx_ugc_campaigns_status")
  @@index([campaign_type], map: "idx_ugc_campaigns_type")
  @@schema("public")
}

model ugc_campaign_escrow {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id    String        @unique @db.Uuid
  deposited_by   String        @db.Uuid
  amount         Decimal       @db.Decimal
  currency       String        @default("RWF")
  status         String        @default("held")
  payment_method String?
  payment_ref    String?
  deposited_at   DateTime?     @default(now()) @db.Timestamptz(6)
  released_at    DateTime?     @db.Timestamptz(6)
  ugc_campaigns  ugc_campaigns @relation(fields: [campaign_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles       profiles      @relation(fields: [deposited_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model ugc_campaign_media {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id     String               @db.Uuid
  type            ugc_media_type       @default(image)
  url             String
  thumbnail_url   String?
  usage           ugc_media_usage      @default(example)
  platform_format ugc_platform_format?
  order_index     Int?                 @default(0)
  created_at      DateTime?            @default(now()) @db.Timestamptz(6)
  ugc_campaigns   ugc_campaigns        @relation(fields: [campaign_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([campaign_id], map: "idx_ugc_campaign_media_campaign_id")
  @@index([campaign_id], map: "idx_ugc_media_camp_id")
  @@schema("public")
}

model ugc_campaign_participants {
  id            String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id   String                   @db.Uuid
  influencer_id String                   @db.Uuid
  status        ugc_participation_status @default(accepted)
  joined_at     DateTime?                @default(now()) @db.Timestamptz(6)
  ugc_campaigns ugc_campaigns            @relation(fields: [campaign_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  influencers   influencers              @relation(fields: [influencer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([campaign_id, influencer_id])
  @@index([campaign_id], map: "idx_ugc_parts_camp_id")
  @@index([influencer_id], map: "idx_ugc_parts_inf_id")
  @@schema("public")
}

model ugc_submissions {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id          String                @db.Uuid
  influencer_id        String                @db.Uuid
  post_url             String
  platform             ugc_platform
  caption              String?
  status               ugc_submission_status @default(pending)
  rejection_reason     String?
  reviewed_by          String?               @db.Uuid
  reviewed_at          DateTime?             @db.Timestamptz(6)
  total_views_earned   BigInt?               @default(0)
  total_earnings       Decimal?              @default(0) @db.Decimal
  last_synced_at       DateTime?             @db.Timestamptz(6)
  created_at           DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?             @default(now()) @db.Timestamptz(6)
  is_suspicious        Boolean?              @default(false)
  fraud_score          Decimal?              @default(0.00) @db.Decimal(5, 2)

  ugc_campaigns        ugc_campaigns         @relation(fields: [campaign_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  influencers          influencers           @relation(fields: [influencer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles             profiles?             @relation(fields: [reviewed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ugc_payouts          ugc_payouts[]
  ugc_reports          ugc_reports[]
  ugc_submission_media ugc_submission_media[]
  ugc_view_snapshots   ugc_view_snapshots[]

  @@unique([campaign_id, post_url])
  @@index([created_at(sort: Desc)], map: "idx_ugc_sub_created_at")
  @@index([campaign_id], map: "idx_ugc_submissions_campaign_id")
  @@index([influencer_id], map: "idx_ugc_submissions_influencer_id")
  @@index([status], map: "idx_ugc_submissions_status")
  @@schema("public")
}

model ugc_submission_media {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submission_id   String               @db.Uuid
  type            ugc_media_type       @default(video)
  url             String
  thumbnail_url   String?
  duration        Int?
  aspect_ratio    String?
  platform_format ugc_platform_format?
  file_size       BigInt?
  mime_type       String?
  order_index     Int?                 @default(0)
  created_at      DateTime?            @default(now()) @db.Timestamptz(6)
  ugc_submissions ugc_submissions      @relation(fields: [submission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([submission_id], map: "idx_ugc_media_sub_id")
  @@schema("public")
}

model ugc_view_snapshots {
  id                     String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
