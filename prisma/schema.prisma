  @@index([created_at(sort: Desc)], map: "idx_ugc_payouts_created_at")
  @@index([influencer_id], map: "idx_ugc_payouts_inf_id")
  @@index([status], map: "idx_ugc_payouts_status")
  @@index([submission_id], map: "idx_ugc_payouts_sub_id")
  @@schema("public")
}

model ugc_reports {
