  net_amount         Decimal?      @db.Decimal(14, 2)
  currency           String?       @default("RWF")
  status             payout_status? @default(pending)
  payout_method      String?       @default("mtn")
  payout_account     String?
  provider_reference String?
  notes              String?
  processed_at       DateTime?     @db.Timestamptz(6)
  created_at         DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?     @default(now()) @db.Timestamptz(6)
  release_date       DateTime?     @db.Timestamptz(6)
  profiles           profiles      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ugc_payouts        ugc_payouts[]

  @@schema("public")
}

model wallets {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id           String    @unique @db.Uuid
  available_balance Decimal?  @default(0) @db.Decimal(14, 2)
  pending_balance   Decimal?  @default(0) @db.Decimal(14, 2)
  total_earned      Decimal?  @default(0) @db.Decimal(14, 2)
  total_paid        Decimal?  @default(0) @db.Decimal(14, 2)
