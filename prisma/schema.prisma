model ugc_campaigns {
  id                        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  brand_id                  String              @db.Uuid
  title                     String
  description               String?
  campaign_type             ugc_campaign_type   @default(clipping)
  status                    ugc_campaign_status @default(draft)
  rate_per_1k_views         Decimal             @default(3.00) @db.Decimal
  total_budget              Decimal             @default(0) @db.Decimal
  spent_budget              Decimal             @default(0) @db.Decimal
  max_payout_per_sub        Decimal?            @default(400) @db.Decimal
  allowed_platforms         String[]            @default(["tiktok", "instagram", "youtube", "x"])
  requires_face             Boolean?            @default(false)
  submission_count          Int?                @default(0)
  approved_count            Int?                @default(0)
  total_views_tracked       BigInt?             @default(0)
  starts_at                 DateTime?           @db.Timestamptz(6)
  ends_at                   DateTime?           @db.Timestamptz(6)
  created_at                DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at                DateTime?           @default(now()) @db.Timestamptz(6)
  min_duration              Int?
  max_duration              Int?
  required_hashtags         Json?               @default("[]")
  required_mentions         Json?               @default("[]")
  required_keywords         Json?               @default("[]")
  music_track_url           String?
  music_artist_name         String?
  promotion_target          String?
  promotion_target_url      String?
  payment_model             ugc_payment_model?  @default(per_views)
  fixed_rate                Decimal?            @default(0) @db.Decimal

  vendors                   vendors                     @relation(fields: [brand_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
